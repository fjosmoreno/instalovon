# --- Database (Postgres, e.g. Neon) ---
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# --- Auth ---
# Min 16 chars; use openssl rand -hex 32 in production.
AUTH_SECRET=replace-me-with-a-32-byte-hex-string

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Optional cost savings: route Gemini through Headroom (https://headroom.ai) ---
# When 1, the worker wraps the Gemini SDK with Headroom's compression proxy.
HEADROOM_ENABLED=0

# --- Worker env (only needed by apps/worker) ---
INSTALOADER_PATH=python3
INSTALOADER_SCRIPT=/abs/path/to/services/instaloader/extract.py
INSTALOADER_TIMEOUT_MS=90000
MAX_POSTS_PER_PROFILE=12
RECENT_DAYS=30
WORKER_POLL_INTERVAL_MS=5000
WORKER_JOB_TIMEOUT_MS=300000
ENABLE_CRAWLER=0
ENABLE_FREE_PROXIES=0
PROXY_LIST_URL=
AI_ENABLED=1
LOG_LEVEL=info
